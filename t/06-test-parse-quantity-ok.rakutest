plan 6;

use Test;
use Recipe::Grammar;

my @cases = (
    ("200", "200"),
    ("2.1", "2.1"),
    ("2_1", "2_1"),
    ("2,1", "2,1"),
    ("2.1", "2.1"),
    ("1/2", "1/2")
);

for @cases -> ($input, $expected) {
    my $m = Recipe::Grammar.parse($input, rule => 'quantity');
    is ~$m.trim, $expected, "quantity('$input')";
}

done-testing;
